.DS_Store
__pycache__/
*.pdf

# Context Preservation System — session-specific runtime data
.claude/context-snapshots/

# D-1: Workflow runtime directories (generated during workflow execution)
verification-logs/
autopilot-logs/
pacs-logs/
review-logs/
diagnosis-logs/
translations/*
!translations/glossary.yaml

# Translation chunking temp directory
.tmp/

# TDD Guard toggle — personal workflow setting (not shared)
.tdd-guard

# Setup Hook logs — runtime diagnostics (regenerated on each run)
.claude/hooks/*.log

# =============================================================================
# GlobalNews Crawling & Analysis System
# =============================================================================

# Python
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
dist/
build/
*.egg

# Data directories (large files, generated at runtime)
data/raw/
data/processed/
data/features/
data/analysis/
data/output/
data/models/
data/logs/

# Keep config files tracked
!data/config/
# Runtime learning state (not version-controlled config)
data/config/bypass_state.json

# Dashboard screenshots (generated by Playwright)
dashboard-*.png

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
.env.production

# OS
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# pytest
.pytest_cache/
htmlcov/
.coverage

# =============================================================================
# Security & Privacy — 개인정보/시크릿 보호
# =============================================================================

# Firebase
firebase-debug.log
firebase*.json
.firebaserc

# Playwright MCP (local browser state, cookies, sessions)
.playwright-mcp/

# Claude runtime locks (session-specific, not shared)
.claude/scheduled_tasks.lock
.claude/state.yaml.lock

# SQLite databases (runtime-generated, may contain crawled content)
data/dedup.sqlite
data/dedup.sqlite-shm
data/dedup.sqlite-wal
*.sqlite-shm
*.sqlite-wal

# Insight pipeline outputs (large, runtime-generated)
data/insights/

# Runtime reports (generated during pipeline execution)
data/reports/

# Personal coding resources
coding-resource/

# Secrets and credentials (belt-and-suspenders with .env above)
*.secret
*.credentials
*_secret.json
*_credentials.json
service-account*.json
oauth*.json

# SSH keys (should never be in project)
*.pem
*.key
id_rsa*
id_ed25519*
